{
  "source": "examples/sample-code-def/source.md",
  "output": "output/공통코드정의서_{version}.xlsx",
  "format": "xlsx",
  "template": "data-spec",
  "theme": "office-modern",
  "h1CleanPattern": "^# 공통 코드",
  "headerCleanUntil": "## 변경 이력",

  "_meta": { "createdBy": "human", "createdAt": "2026-02-27" },

  "docInfo": {
    "title": "공통 코드 정의서",
    "subtitle": "Common Code Specification",
    "version": "v1.0",
    "author": "시스템관리팀",
    "company": "gendocs",
    "createdDate": "2026-02-27",
    "modifiedDate": "2026-02-27"
  },

  "xlsx": {
    "sheetMapping": "h2",
    "coverSheet": true,
    "freezeHeaders": true,
    "autoFilter": true
