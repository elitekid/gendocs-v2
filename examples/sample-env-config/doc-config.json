{
  "source": "examples/sample-env-config/source.md",
  "output": "output/환경설정매트릭스_{version}.xlsx",
  "format": "xlsx",
  "template": "data-spec",
  "theme": "office-modern",
  "h1CleanPattern": "^# 환경별 설정",
  "headerCleanUntil": "## 변경 이력",

  "_meta": { "createdBy": "human", "createdAt": "2026-02-27" },

  "docInfo": {
    "title": "환경별 설정 매트릭스",
    "subtitle": "Environment Configuration Matrix",
    "version": "v1.0",
    "author": "인프라팀",
    "company": "gendocs",
    "createdDate": "2026-02-27",
    "modifiedDate": "2026-02-27"
  },

  "xlsx": {
    "sheetMapping": "h2",
    "coverSheet": true,
    "freezeHeaders": true,
    "autoFilter": true,
    "skipProse": true
  },

  "tableWidths": {
    "버전|날짜|작성자|변경 내용": [8, 14, 12, 45],
    "항목|개발|스테이징|운영|비고": [20, 22, 22, 22, 22]
  }
}
