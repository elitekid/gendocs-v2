{
  "source": "examples/sample-api-endpoints/source.md",
  "output": "output/API엔드포인트목록_{version}.xlsx",
  "format": "xlsx",
  "template": "data-spec",
  "theme": "office-modern",
  "h1CleanPattern": "^# API 엔드포인트",
  "headerCleanUntil": "## 변경 이력",

  "_meta": { "createdBy": "human", "createdAt": "2026-02-27" },

  "docInfo": {
    "title": "API 엔드포인트 목록",
    "subtitle": "REST API Endpoint Catalog",
    "version": "v1.0",
    "author": "플랫폼개발팀",
    "company": "gendocs",
    "createdDate": "2026-02-27",
    "modifiedDate": "2026-02-27"
  },

  "xlsx": {
    "sheetMapping": "h2",
    "coverSheet": true,
    "freezeHeaders": true,
    "autoFilter": true,
    "skipProse": true
  },

  "tableWidths": {
    "버전|날짜|작성자|변경 내용": [8, 14, 12, 45],
    "Method|Path|설명|인증|요청 파라미터|응답 코드": [8, 30, 20, 16, 28, 14]
  }
}
